{
  "expo": {
    "name": "SplitClean",
    "slug": "splitclean",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "splitclean",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d71e1e3b-947b-4633-ad6b-509a04718dd1",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.splitclean.app"
    },
    "android": {
      "package": "com.splitclean.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d71e1e3b-947b-4633-ad6b-509a04718dd1"
      }
    },
    "owner": "mishuk77"
  }
}
